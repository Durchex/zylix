# =========================================================
# ZYLIX — Environment Variables
# Copy this file to .env and .env.local as needed, then fill in real values.
# Never commit the actual .env file.
# =========================================================

# --- App ---
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# --- Database (PostgreSQL via Prisma) ---
DATABASE_URL=postgresql://zylix:zylix@localhost:5432/zylix?schema=public

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Auth / JWT ---
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
TWO_FACTOR_ISSUER=Zylix

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Payments: Africa-first primary providers ---
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_ENCRYPTION_KEY=
FLUTTERWAVE_WEBHOOK_SECRET_HASH=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=

# --- Payments: global secondary providers ---
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
APPLE_PAY_MERCHANT_ID=
GOOGLE_PAY_MERCHANT_ID=

# --- Support / Messaging ---
WHATSAPP_BUSINESS_NUMBER=
LIVE_CHAT_WIDGET_KEY=
NEWSLETTER_PROVIDER_API_KEY=

# --- Currency / Locale ---
DEFAULT_CURRENCY=NGN
DEFAULT_LOCALE=en
